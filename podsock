#!/bin/bash

# Podsock - Simple wrapper for podman that adds new +flags
# that are shorthand for common operations

# Set to 0 to omit --init from created containers
: "${PODSOCK_INIT:=1}"

# Set this to your desired XDG_RUNTIME_DIR inside the container
: "${PODSOCK_RTDIR:=/run/user/${UID}}"

die() {
    printf '%s\n' "$*" >&2
    exit 1
}

command -v podman >/dev/null 2>&1 || die "Error: podman is required but not installed"

cmd=()
dryrun=0

run_podman() {
    if [[ "${PODSOCK_DRYRUN:-}" == "1" ]] || (( dryrun )); then
        printf '%q ' "${cmd[@]}"
        echo
    else
        exec "${cmd[@]}"
    fi
    exit
}

show_help() {
    local target_cmd=$1
    local target_podman_cmd=$target_cmd

    echo "Podsock - podman wrapper with +flags"
    echo
    echo "Usage: podsock [+flags] <command> [args...]"
    echo

    local available_flags=()
    case "$target_cmd" in
        run|create)
            available_flags=(t T w s g n d \?)
            ;;
        shell)
            available_flags=(\?)
            target_podman_cmd="exec"
            ;;
        helm)
            available_flags=(\?)
            target_podman_cmd="start"
            ;;
        help)
            echo "Show help for a podsock command."
            echo "Usage: podsock help <command>"
            return
            ;;
        *)
            available_flags=(\?)
            ;;
    esac

    if [[ -n "$target_cmd" ]]; then
        echo "Available +flags for '$target_cmd':"
        for f in "${available_flags[@]}"; do
            case "$f" in
                t) echo "  +t  Terminal interactivity (uses \$TERM)" ;;
                T) echo "  +T  Terminal interactivity (forces xterm-256color)" ;;
                w) echo "  +w  Wayland display forwarding" ;;
                s) echo "  +s  SSH agent socket forwarding" ;;
                g) echo "  +g  GPU/graphics device access" ;;
                n) echo "  +n  Host network with extra capabilities" ;;
                d) echo "  +d  Debug capabilities (ptrace, perfmon)" ;;
                \?) echo "  +?  Dry run (print command without executing)" ;;
            esac
        done
        echo
        echo "--- Podman help for '$target_podman_cmd' ---"
        podman "$target_podman_cmd" --help
    else
        echo "Subcommands:"
        echo "  shell <container> [command]  Run a shell (or command) in a running container"
        echo "  helm <container>             Start a container interactively"
        echo
        echo "Use 'podsock <command> --help' for command-specific help."
        echo
        echo "--- Podman help ---"
        podman --help
    fi
}

apply_flag() {
    local flag=$1
    case "$flag" in
        t)
            cmd+=(--interactive --tty "--env=TERM=${TERM}")
            ;;
        T)
            cmd+=(--interactive --tty "--env=TERM=xterm-256color")
            ;;
        w)
            [[ -n "${WAYLAND_DISPLAY:-}" ]] || die "Error: WAYLAND_DISPLAY not set"
            [[ -n "${XDG_RUNTIME_DIR:-}" ]] || die "Error: XDG_RUNTIME_DIR not set"
            [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]] || die "Error: Wayland socket not found at ${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}"
            cmd+=(--env="WAYLAND_DISPLAY=${WAYLAND_DISPLAY}")
            cmd+=(--volume="${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}:${PODSOCK_RTDIR}/${WAYLAND_DISPLAY}:ro")
            ;;
        s)
            [[ -n "${SSH_AUTH_SOCK:-}" ]] || die "Error: SSH_AUTH_SOCK not set"
            [[ -S "${SSH_AUTH_SOCK}" ]] || die "Error: SSH socket not found at ${SSH_AUTH_SOCK}"
            cmd+=(--env="SSH_AUTH_SOCK=${PODSOCK_RTDIR}/ssh-agent.socket")
            cmd+=(--volume="${SSH_AUTH_SOCK}:${PODSOCK_RTDIR}/ssh-agent.socket:ro")
            ;;
        g)
            [[ -d /dev/dri ]] || die "Error: /dev/dri not found"
            cmd+=(--device /dev/dri)
            ;;
        n)
            cmd+=(--network=host "--cap-add=NET_RAW,NET_ADMIN,NET_BIND_SERVICE")
            ;;
        d)
            cmd+=("--cap-add=SYS_PTRACE,PERFMON" --security-opt seccomp=unconfined)
            ;;
        \?)
            dryrun=1
            ;;
        *)
            die "Error: Unknown flag: +$flag"
            ;;
    esac
}

# ---- Two-pass argument processing ----

all_args=("$@")
podsock_flags=()
subcommand=""
subcommand_idx=-1

# Known podman and podsock subcommands
known_subcommands="run create exec start stop rm rmi ps images pull push build logs system machine pod network volume image container play generate inspect stats top diff export import load save tag unmount wait attach checkpoint commit cp events init kill mount pause port prune restart unpause update shell helm help"

# Pass 1: find subcommand, collect +flags, stop at --
for (( i = 0; i < $#; i++ )); do
    arg="${all_args[$i]}"

    if [[ "$arg" == -- ]]; then
        break
    fi

    if [[ "$arg" == +* ]]; then
        flags=${arg#+}
        for (( j = 0; j < ${#flags}; j++ )); do
            podsock_flags+=("${flags:$j:1}")
        done
    elif [[ -z "$subcommand" ]]; then
        if [[ " $known_subcommands " == *" $arg "* ]]; then
            subcommand="$arg"
            subcommand_idx=$i
        fi
    fi
done

# Handle help request (-h / --help anywhere)
help_requested=0
for arg in "${all_args[@]}"; do
    if [[ "$arg" == "-h" ]] || [[ "$arg" == "--help" ]]; then
        help_requested=1
        break
    fi
done

if (( help_requested )); then
    show_help "$subcommand"
    exit 0
fi

# Handle explicit 'help' subcommand
if [[ "$subcommand" == "help" ]]; then
    target_cmd=""
    if (( subcommand_idx + 1 < $# )); then
        target_cmd="${all_args[$((subcommand_idx + 1))]}"
    fi
    show_help "$target_cmd"
    exit 0
fi

# Build the command
cmd=(podman)

# Add global options (everything before subcommand, minus +flags)
if (( subcommand_idx >= 0 )); then
    for (( i = 0; i < subcommand_idx; i++ )); do
        arg="${all_args[$i]}"
        if [[ "$arg" != +* ]]; then
            cmd+=("$arg")
        fi
    done
fi

# ---- shell ----
if [[ "$subcommand" == "shell" ]]; then
    for f in "${podsock_flags[@]}"; do
        if [[ "$f" != "?" ]]; then
            die "Error: +$f flag is not supported for 'shell' command (only +? is allowed)"
        fi
    done
    for f in "${podsock_flags[@]}"; do
        apply_flag "$f"
    done
    (( $# > subcommand_idx + 1 )) || die "Usage: ${0##*/} shell <container> [command]"
    cmd+=(exec -it)
    for (( i = subcommand_idx + 1; i < $#; i++ )); do
        cmd+=("${all_args[$i]}")
    done
    run_podman
fi

# ---- helm ----
if [[ "$subcommand" == "helm" ]]; then
    for f in "${podsock_flags[@]}"; do
        if [[ "$f" != "?" ]]; then
            die "Error: +$f flag is not supported for 'helm' command (only +? is allowed)"
        fi
    done
    for f in "${podsock_flags[@]}"; do
        apply_flag "$f"
    done
    (( $# > subcommand_idx + 1 )) || die "Usage: ${0##*/} helm <container>"
    cmd+=(start -ai)
    cmd+=("${all_args[$((subcommand_idx + 1))]}")
    run_podman
fi

# ---- run / create ----
case "$subcommand" in
    run|create)
        cmd+=("$subcommand")
        for f in "${podsock_flags[@]}"; do
            apply_flag "$f"
        done
        cmd+=(--tmpfs "${PODSOCK_RTDIR}:mode=0700,U" --security-opt label=disable --userns=keep-id "--env=XDG_RUNTIME_DIR=${PODSOCK_RTDIR}")
        if (( PODSOCK_INIT )); then
            cmd+=(--init)
        fi
        for (( i = subcommand_idx + 1; i < $#; i++ )); do
            arg="${all_args[$i]}"
            if [[ "$arg" == -- ]]; then
                cmd+=(--)
                for (( j = i + 1; j < $#; j++ )); do
                    cmd+=("${all_args[$j]}")
                done
                break
            fi
            if [[ "$arg" != +* ]]; then
                cmd+=("$arg")
            fi
        done
        run_podman
        ;;
esac

# ---- Other podman subcommands ----
if [[ -n "$subcommand" ]]; then
    cmd+=("$subcommand")
    for f in "${podsock_flags[@]}"; do
        apply_flag "$f"
    done
    for (( i = subcommand_idx + 1; i < $#; i++ )); do
        arg="${all_args[$i]}"
        if [[ "$arg" == -- ]]; then
            cmd+=(--)
            for (( j = i + 1; j < $#; j++ )); do
                cmd+=("${all_args[$j]}")
            done
            break
        fi
        if [[ "$arg" != +* ]]; then
            cmd+=("$arg")
        fi
    done
    run_podman
fi

# ---- No subcommand found ----
for arg in "${all_args[@]}"; do
    if [[ "$arg" != +* ]]; then
        cmd+=("$arg")
    fi
done
run_podman
